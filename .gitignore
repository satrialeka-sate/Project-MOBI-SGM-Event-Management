# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# generated prisma client
/generated/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Windows reserved device names (can cause Turbopack panics)
nul
CON
PRN
AUX
COM1
LPT1

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
