generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  SUPERVISOR
  PERMITTER
  SPG

  @@map("user_role")
}

enum UserLevel {
  PERMITTER
  SPG
  TEAM_LEADER
  PIC
  PO

  @@map("user_level")
}

enum UserScope {
  REGION
  ALL

  @@map("user_scope")
}

model Region {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  permitters Permitter[]
  events     Event[]

  @@map("regions")
}

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  username    String?   @unique
  name        String
  password    String?
  googleId    String?   @unique
  image       String?
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  role        UserRole  @default(PERMITTER)
  level       UserLevel @default(PERMITTER)
  scope       UserScope @default(REGION)
  regionId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  region      Region       @relation(fields: [regionId], references: [id])
  permitters  Permitter[]  @relation("PermitterUser")
  spgEvents   Permitter[]  @relation("SPGUser")
  attendances Attendance[]

  @@map("users")
}

enum EventStatus {
  UPCOMING
  ONGOING
  COMPLETED

  @@map("event_status")
}

enum PreviousMilk {
  SGM
  SUSU_BUBUK
  NON_SUSU_BUBUK
  NEW_TO_GUM
  OTHERS

  @@map("previous_milk")
}

model Permitter {
  id           String          @id @default(cuid())
  permitterId  String
  spgId        String?
  regionId     String
  cycle        String
  venueName    String
  venueAddress String
  venuePIC     String
  venuePICPhone String         @default("")
  eventDate    DateTime
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  permitter User              @relation("PermitterUser", fields: [permitterId], references: [id])
  spg       User?             @relation("SPGUser", fields: [spgId], references: [id])
  region    Region            @relation(fields: [regionId], references: [id])
  schools   PermitterSchool[]
  event     Event?

  @@map("permitters")
}

model MasterProduct {
  id          String   @id @default(cuid())
  productName String   @unique
  price       Int
  package     String   @default("")
  gimmick     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sellings Selling[]

  @@map("master_products")
}

model Event {
  id           String   @id @default(cuid())
  permitterId  String   @unique
  regionId     String
  venueName    String
  venueAddress String
  eventDate    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  permitter   Permitter   @relation(fields: [permitterId], references: [id])
  region      Region      @relation(fields: [regionId], references: [id])
  attendances Attendance[]
  sellings    Selling[]
  contacts    Contact[]

  @@index([eventDate])
  @@map("events")
}

model Attendance {
  id           String   @id @default(cuid())
  eventId      String
  userId       String
  photo        String
  attendanceAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
  @@index([eventId])
  @@map("attendances")
}

model Selling {
  id           String      @id @default(cuid())
  eventId      String
  sellingDate  DateTime    @default(now())
  previousMilk PreviousMilk
  productId    String
  productName  String
  gimmick      String
  createdBy    String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  event   Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  product MasterProduct @relation(fields: [productId], references: [id])

  @@index([eventId])
  @@map("sellings")
}

model Contact {
  id           String   @id @default(cuid())
  eventId      String
  contactDate  DateTime @default(now())
  totalContact Int
  createdBy    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("contacts")
}

model PermitterSchool {
  id            String   @id @default(cuid())
  permitterId   String
  name          String
  schoolAddress String
  totalStudents Int
  picName       String
  picPhone      String
  order         Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  permitter Permitter @relation(fields: [permitterId], references: [id], onDelete: Cascade)

  @@unique([permitterId, order])
  @@map("permitter_schools")
}
