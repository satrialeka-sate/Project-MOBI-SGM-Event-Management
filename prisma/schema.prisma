generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

// ── Shadow database fix ─────────────────────────────────────────────────
// If migration fails with "relation does not exist", run:
//   npx prisma migrate resolve --applied "<migration_name>"
// to mark problematic migrations as applied in the shadow DB.

datasource db {
  provider = "postgresql"
}

model Region {
  id         String      @id @default(cuid())
  name       String      @unique
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  events     Event[]
  permitters Permitter[]
  users      User[]

  @@map("regions")
}

model User {
  id          String       @id @default(cuid())
  email       String       @unique
  name        String
  password    String?
  phone       String?
  regionId    String
  status      UserStatus   @default(ACTIVE)

  // Approval audit fields
  approvedBy    String?
  approvedAt    DateTime?
  rejectedBy    String?
  rejectedAt    DateTime?
  rejectionReason String?

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  level       UserLevel    @default(PERMITTER)
  scope       UserScope    @default(REGION)
  googleId    String?      @unique
  image       String?
  isActive    Boolean      @default(true)
  lastLoginAt DateTime?
  role        UserRole     @default(PERMITTER)
  username    String?      @unique
  attendances Attendance[]
  permitters  Permitter[]  @relation("PermitterUser")
  spgEvents   Permitter[]  @relation("SPGUser")
  region      Region       @relation(fields: [regionId], references: [id])

  @@map("users")
}

model Permitter {
  id            String            @id @default(cuid())
  permitterId   String
  spgId         String?
  eventDate     DateTime
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  cycle         String
  regionId      String
  venueAddress  String
  venueName     String
  venuePIC      String
  venuePICPhone String            @default("")
  status        permitter_status  @default(PENDING)
  event         Event?
  schools       PermitterSchool[]
  permitter     User              @relation("PermitterUser", fields: [permitterId], references: [id])
  region        Region            @relation(fields: [regionId], references: [id])
  spg           User?             @relation("SPGUser", fields: [spgId], references: [id])

  @@map("permitters")
}

model MasterProduct {
  id          String    @id @default(cuid())
  productName String    @unique
  gimmick     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  price       Int
  package     String    @default("")
  sellings    Selling[]

  @@map("master_products")
}

model Event {
  id           String       @id @default(cuid())
  permitterId  String       @unique
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  eventDate    DateTime
  regionId     String
  venueAddress String
  venueName    String
  attendances  Attendance[]
  contacts     Contact[]
  permitter    Permitter    @relation(fields: [permitterId], references: [id])
  region       Region       @relation(fields: [regionId], references: [id])
  sellings     Selling[]

  @@index([eventDate])
  @@map("events")
}

model Attendance {
  id           String   @id @default(cuid())
  eventId      String
  photo        String
  attendanceAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userId       String
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
  @@index([eventId])
  @@map("attendances")
}

model Selling {
  id           String        @id @default(cuid())
  eventId      String
  sellingDate  DateTime      @default(now())
  previousMilk PreviousMilk
  productId    String
  createdBy    String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  gimmick      String
  productName  String
  event        Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  product      MasterProduct @relation(fields: [productId], references: [id])

  @@index([eventId])
  @@map("sellings")
}

model Contact {
  id           String   @id @default(cuid())
  eventId      String
  contactDate  DateTime @default(now())
  totalContact Int
  createdBy    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("contacts")
}

model PermitterSchool {
  id            String    @id @default(cuid())
  permitterId   String
  name          String
  order         Int
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  schoolAddress String
  totalStudents Int
  picName       String
  picPhone      String
  permitter     Permitter @relation(fields: [permitterId], references: [id], onDelete: Cascade)

  @@unique([permitterId, order])
  @@map("permitter_schools")
}

enum UserRole {
  ADMIN
  SUPERVISOR
  PERMITTER
  SPG
  CLIENT

  @@map("user_role")
}

enum UserLevel {
  PERMITTER
  SPG
  TEAM_LEADER
  PIC
  PO

  @@map("user_level")
}

enum UserScope {
  REGION
  ALL

  @@map("user_scope")
}

enum EventStatus {
  UPCOMING
  ONGOING
  COMPLETED

  @@map("event_status")
}

enum PreviousMilk {
  SGM
  SUSU_BUBUK
  NON_SUSU_BUBUK
  NEW_TO_GUM
  OTHERS

  @@map("previous_milk")
}

enum UserStatus {
  PENDING
  ACTIVE
  REJECTED

  @@map("user_status")
}

enum permitter_status {
  PENDING
  APPROVED
  REJECTED
}
