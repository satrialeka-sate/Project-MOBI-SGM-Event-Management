generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  SUPERVISOR
  PERMITTER
  SPG

  @@map("user_role")
}

enum UserLevel {
  PERMITTER
  SPG
  TEAM_LEADER
  PIC
  PO

  @@map("user_level")
}

enum UserScope {
  REGION
  ALL

  @@map("user_scope")
}

model Region {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  permitters Permitter[]

  @@map("regions")
}

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  name        String
  password    String?
  googleId    String?   @unique
  image       String?
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  role        UserRole  @default(PERMITTER)
  level       UserLevel @default(PERMITTER)
  scope       UserScope @default(REGION)
  regionId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  region     Region      @relation(fields: [regionId], references: [id])
  permitters Permitter[] @relation("PermitterUser")
  spgEvents  Permitter[] @relation("SPGUser")

  @@map("users")
}

enum EventStatus {
  SCHEDULED
  ONGOING
  COMPLETED
  CANCELLED
}

model Permitter {
  id           String   @id @default(cuid())
  permitterId  String
  spgId        String?
  regionId     String
  cycle        String
  venueName    String
  venueAddress String
  venuePIC     String
  venuePICPhone String  @default("")
  eventDate    DateTime
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  permitter User              @relation("PermitterUser", fields: [permitterId], references: [id])
  spg       User?             @relation("SPGUser", fields: [spgId], references: [id])
  region    Region            @relation(fields: [regionId], references: [id])
  schools   PermitterSchool[]
  event     Event?

  @@map("permitters")
}

model Event {
  id              String      @id @default(cuid())
  permitterId     String      @unique
  startTime       DateTime?
  endTime         DateTime?
  actualStartTime DateTime?
  actualEndTime   DateTime?
  startedById     String?
  completedById   String?
  notes           String?
  photoUrl        String?
  status          EventStatus @default(SCHEDULED)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  permitter Permitter @relation(fields: [permitterId], references: [id])

  @@map("events")
}

model PermitterSchool {
  id            String   @id @default(cuid())
  permitterId   String
  name          String
  schoolAddress String
  totalStudents Int
  picName       String
  picPhone      String
  order         Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  permitter Permitter @relation(fields: [permitterId], references: [id], onDelete: Cascade)

  @@unique([permitterId, order])
  @@map("permitter_schools")
}
